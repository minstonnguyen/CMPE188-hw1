__pycache__/
*.py[cod]
*$py.class
*.pyo

# Model checkpoint files
*.pt
*.pth
*.ckpt

# Keep only folders and .py scripts and ignore other file types
*.json
*.md

# OS / IDE
.DS_Store
Thumbs.db
*.swp
*~
